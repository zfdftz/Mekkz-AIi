# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_MAX_TURNS=6
# OLLAMA_NUM_CTX=2048
# OLLAMA_NUM_PREDICT=420
# OLLAMA_TEMPERATURE=0.6
# Schnelleres Modell z.B.: OLLAMA_MODEL=llama3.2:3b
# pollinations = kostenlos (Standard), openai = kostenpflichtig, ollama = lokal
IMAGE_PROVIDER=pollinations
POLLINATIONS_IMAGE_MODEL=turbo
OPENAI_IMAGE_MODEL=gpt-image-1

NEXT_PUBLIC_APP_NAME=mekkz AI
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

