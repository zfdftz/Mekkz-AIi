NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=openai
# Bild-Uploads: groq = gratis (Vision), openai = kostenpflichtig
VISION_PROVIDER=groq
OPENAI_MODEL=gpt-4.1
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.5-pro
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TURNS=2
GROQ_MAX_TOKENS=360
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MAX_TOKENS=520
OPENAI_VISION_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_VISION_MODEL=llava
OLLAMA_IMAGE_MODEL=x/flux2-klein:4b-fp8
# Optional Ollama speed tuning (Plan-Delays bleiben unveraendert):
# OLLAMA_KEEP_ALIVE=30m
# OLLAMA_MAX_TURNS=6
# OLLAMA_NUM_CTX=2048
# OLLAMA_NUM_PREDICT=420
# OLLAMA_TEMPERATURE=0.6
# Schnelleres Modell z.B.: OLLAMA_MODEL=llama3.2:3b
# --- Bilder (kostenlos) ---
# free = gratis, laedt im Browser (mekkzai.com Standard, kein Guthaben noetig)
# ollama = lokal testen (Bilder nur macOS — Windows nutzt free oder SD WebUI)
# mekkz = eigener PC/Server ueber MEKKZ_IMAGE_WORKER_URL
# pollinations = kostenpflichtig mit API-Key
IMAGE_PROVIDER=free
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=flux

# Windows: Stable Diffusion WebUI + npm run image-worker
# SD_WEBUI_URL=http://127.0.0.1:7860
MEKKZ_IMAGE_WORKER_URL=
MEKKZ_IMAGE_WORKER_SECRET=

# Registrierung: 6-stelliger Code per Supabase Auth OTP (kostenlos, kein Resend)
# Supabase Dashboard -> Authentication -> Email -> OTP expiry = 1800 (30 Min.)
# Anonymous Sign-Ins aktivieren fuer Gast-Modus
# Google Login: Provider aktivieren, Redirect URLs:
#   https://mekkzai.com/auth/callback
#   http://127.0.0.1:3000/auth/callback

NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Mobile app (Capacitor) — lädt die Live-Website in der Store-App
CAPACITOR_SERVER_URL=https://mekkzai.com
# Nach Veröffentlichung in den Stores:
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.mekkzai.app
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXXX

# Stripe (monatliche Abos: Plus 3 EUR, Pro 10 EUR, Ultra 29 EUR)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Preis-IDs price_... aus Stripe Dashboard (Produkt „MEKKZAI PLUS“)
STRIPE_PRICE_PLUS=
# Zahlungslinks (empfohlen) — aus Stripe Dashboard → Zahlungslinks
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_ULTRA=https://buy.stripe.com/...
# Optional statt Links: Preis-IDs price_...
STRIPE_PRICE_PRO=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_ULTRA=
# Nur fuer lokale Tests ohne Zahlung, wenn Stripe konfiguriert ist:
# ALLOW_DEMO_PLAN_UPGRADE=true

# Google AdSense (https://adsense.google.com)
# 1. AdSense-Konto erstellen & mekkzai.com genehmigen lassen
# 2. Anzeigen -> Anzeigen nach Einheit -> 3 Display-Anzeigen anlegen (Landing, Sidebar, Feed)
# 3. ca-pub-... und Slot-IDs hier eintragen, dann Redeploy
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-9259103716434934
NEXT_PUBLIC_ADSENSE_SLOT_LANDING=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_FEED=
