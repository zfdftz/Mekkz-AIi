ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4.1
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.5-pro
